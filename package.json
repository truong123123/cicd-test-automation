{
  "name": "cicd-test-automation",
  "version": "1.0.0",
  "description": "A case study on integrating test automation with CI/CD using GitHub Actions",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=tests/unit --coverage --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand --forceExit",
    "test:e2e": "jest --testPathPattern=tests/e2e --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:ci": "jest --ci --coverage --runInBand --forceExit",
    "lint": "eslint src/ tests/ --ext .js",
    "lint:fix": "eslint src/ tests/ --ext .js --fix"
  },
  "keywords": [
    "ci-cd",
    "github-actions",
    "test-automation",
    "jest",
    "express"
  ],
  "author": "CI/CD Case Study",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "puppeteer-core": "^25.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true
  }
}
